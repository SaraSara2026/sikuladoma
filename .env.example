# Neon DB connection string
# Get yours at: https://console.neon.tech/
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://...

# JWT secret pro podepisování session tokenů.
# Vygeneruj: openssl rand -base64 48
# Musí být ≥ 32 znaků. Nikdy necommituj reálnou hodnotu, jen ji nastav
# v .env.local lokálně a v Vercel → Settings → Environment Variables produkčně.
JWT_SECRET=
